# Defaults for host-based development with `pnpm dev`.
# Docker Compose overrides the internal Postgres and Mailpit hosts for the `app`
# service, so these values stay convenient when the Node process runs locally.
HOST=0.0.0.0
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/releases
# Public base URL used in confirmation and unsubscribe links.
APP_BASE_URL=http://localhost:3000
# API key required for /api routes.
API_KEY=local-dev-key
# Release polling interval in milliseconds.
SCAN_INTERVAL_MS=60000
# Optional GitHub token for higher API rate limits.
GITHUB_TOKEN=
# Mailpit-compatible SMTP defaults for local development.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
